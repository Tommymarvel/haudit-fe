{
  "mcpServers": {
    "Figma": {
      "command": "npx",
      "args": [
        "-y",
        "figma-developer-mcp",
        "--figma-api-key",
        "${input:figmaApiKey}"
      ],
      "inputs": [
        {
          "type": "promptString",
          "id": "figmaApiKey",
          "description": "Figma API Key",
          "password": true
        }
      ]
    }
  }
}
